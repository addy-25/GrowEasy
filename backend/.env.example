# Copy this file to .env and fill in your own values:  cp .env.example .env

# API key for OpenAI or any OpenAI-compatible provider
OPENAI_API_KEY=sk-your-key-here

# Optional: base URL for OpenAI-compatible providers (e.g. a proxy service).
# Remove this line to use the official OpenAI API directly.
OPENAI_BASE_URL=https://your-provider.example.com/v1

# Port the Express server listens on
PORT=4000

# How many AI batches to process in parallel (default 1 = sequential).
# Raise to 5+ on providers without per-key concurrency limits (e.g. official OpenAI).
EXTRACTOR_CONCURRENCY=1
